# Copy this file to .env and fill in your values.
# NEVER commit .env or share your private key.

# Wallet that pays gas and signs the deploy transaction (Genesis / Deployer)
DEPLOYER_PRIVATE_KEY=

# Base RPC endpoints (defaults work for most users)
BASE_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Get a free key at https://basescan.org/myapikey (used for contract verification)
BASESCAN_API_KEY=

# puriKRON official wallets (mainnet — published on www.purikron.com/verify/)
LP_WALLET=0xa5eD5A8B85c9AB7F808B3bD78ee436DEc25ecdD6
ECOSYSTEM_BENEFICIARY=0x172e02190e65Fa5f5C5224Dc9d8664E25Cb78809
FOUNDER_BENEFICIARY=0x6bB7054DB758bd197Aa15547F45773eb44bD33Ff

# Token metadata
TOKEN_NAME=puriKRON
TOKEN_SYMBOL=PURIKRON

# Optional: warn if deployer does not match expected genesis address
EXPECTED_DEPLOYER=0xc282390c7eee86628Bd73c472f0ebf453CaB740b
